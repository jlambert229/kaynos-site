{
  "name": "kaynos-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "preview": "vite preview",
    "preview:open": "node scripts/build.mjs && vite preview --open --host 127.0.0.1 --port 4173",
    "test": "vitest run",
    "test:e2e": "node scripts/build.mjs && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:ios": "playwright test --project=ios-safari --project=ios-safari-landscape",
    "test:e2e:mobile": "playwright test --project=ios-safari --project=android-chrome",
    "figma:export": "node scripts/figma-export.mjs",
    "figma:export:dry": "node scripts/figma-export.mjs --dry-run",
    "lint": "eslint .",
    "postbuild": "node scripts/generate-sitemap.mjs && node scripts/verify-prerender-seo.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "lucide-react": "^1.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-helmet-async": "3.0.0",
    "react-router-dom": "7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.27.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "vite": "^8.0.8",
    "vite-prerender-plugin": "^0.5.13",
    "vitest": "^4.1.3"
  }
}
