{
  "name": "kaynos-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build.mjs",
    "preview": "vite preview",
    "preview:open": "node scripts/build.mjs && vite preview --open --host 127.0.0.1 --port 4173",
    "test": "vitest run",
    "test:e2e": "node scripts/build.mjs && playwright test",
    "test:e2e:ui": "node scripts/build.mjs && playwright test --ui",
    "test:e2e:chromium": "node scripts/build.mjs && playwright test --project=chromium",
    "test:e2e:firefox": "node scripts/build.mjs && playwright test --project=firefox",
    "test:e2e:webkit": "node scripts/build.mjs && playwright test --project=webkit",
    "test:e2e:ios": "node scripts/build.mjs && playwright test --project=ios-safari --project=ios-safari-landscape",
    "test:e2e:mobile": "node scripts/build.mjs && playwright test --project=ios-safari --project=android-chrome",
    "verify:remote-headers": "node scripts/verify-remote-headers.mjs",
    "figma:export": "node scripts/figma-export.mjs",
    "figma:export:dry": "node scripts/figma-export.mjs --dry-run",
    "lint": "eslint .",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "postbuild": "node scripts/generate-sitemap.mjs && node scripts/generate-security-txt.mjs && node scripts/verify-prerender-seo.mjs && node scripts/strip-build-only-chunks.mjs && node scripts/compute-csp.mjs && node scripts/verify-sitemap-dist.mjs && node scripts/verify-dist-headers.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "3.0.0",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "vite": "^8.0.13",
    "vite-prerender-plugin": "^0.5.13",
    "vitest": "^4.1.6"
  }
}
